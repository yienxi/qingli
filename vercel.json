{
  "version": 3,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "css/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "js/*.js",
      "use": "@vercel/static"
    },
    {
      "src": "public/*.*",
      "use": "@vercel/static"
    }
  ],
  "functions": {
    "api/ical.js": {
      "runtime": "@vercel/node@3"
    },
    "api/holidays.js": {
      "runtime": "@vercel/node@3"
    }
  },
  "routes": [
    {
      "src": "/api/ical(.*)",
      "dest": "/api/ical.js"
    },
    {
      "src": "/api/holidays(.*)",
      "dest": "/api/holidays.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}